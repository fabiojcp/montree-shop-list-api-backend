{
  "info": {
    "name": "Montree Shop List API",
    "description": "API REST para gerenciamento de catálogo de itens e lista de compras com compradores aleatórios do GitHub.\n\nFeatures: health check, paginação, X-Request-Id, retry com backoff, response envelope.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:3333" },
    { "key": "prod_url", "value": "https://montree-shop-list-api-backend.fly.dev" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        { "name": "Health Check", "request": { "method": "GET", "url": { "raw": "{{base_url}}/health", "host": ["{{base_url}}"], "path": ["health"] } } }
      ]
    },
    {
      "name": "Itens",
      "item": [
        {
          "name": "POST /itens — Criar",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"nome\": \"Notebook\",\n  \"preco\": 3500.00,\n  \"qtd_atual\": 10\n}" },
            "url": { "raw": "{{base_url}}/itens", "host": ["{{base_url}}"], "path": ["itens"] }
          }
        },
        {
          "name": "POST /itens — Erro: nome vazio",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"nome\": \"\",\n  \"preco\": 10,\n  \"qtd_atual\": 1\n}" },
            "url": { "raw": "{{base_url}}/itens", "host": ["{{base_url}}"], "path": ["itens"] }
          }
        },
        {
          "name": "POST /itens — Erro: campos faltando",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{}" },
            "url": { "raw": "{{base_url}}/itens", "host": ["{{base_url}}"], "path": ["itens"] }
          }
        },
        {
          "name": "GET /itens — Listar (paginação padrão)",
          "request": { "method": "GET", "url": { "raw": "{{base_url}}/itens", "host": ["{{base_url}}"], "path": ["itens"] } }
        },
        {
          "name": "GET /itens — Paginação (?page=1&limit=2)",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/itens?page=1&limit=2", "host": ["{{base_url}}"], "path": ["itens"], "query": [{ "key": "page", "value": "1" }, { "key": "limit", "value": "2" }] }
          }
        }
      ]
    },
    {
      "name": "Compras",
      "item": [
        {
          "name": "POST /compras — Criar (item_id válido)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"item_id\": 1\n}" },
            "url": { "raw": "{{base_url}}/compras", "host": ["{{base_url}}"], "path": ["compras"] }
          }
        },
        {
          "name": "POST /compras — Erro: item_id inexistente (404)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"item_id\": 999\n}" },
            "url": { "raw": "{{base_url}}/compras", "host": ["{{base_url}}"], "path": ["compras"] }
          }
        },
        {
          "name": "POST /compras — Erro: item_id faltando",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{}" },
            "url": { "raw": "{{base_url}}/compras", "host": ["{{base_url}}"], "path": ["compras"] }
          }
        },
        {
          "name": "GET /compras — Listar (com item relacionado)",
          "request": { "method": "GET", "url": { "raw": "{{base_url}}/compras", "host": ["{{base_url}}"], "path": ["compras"] } }
        },
        {
          "name": "GET /compras — Paginação (?page=1&limit=5)",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/compras?page=1&limit=5", "host": ["{{base_url}}"], "path": ["compras"], "query": [{ "key": "page", "value": "1" }, { "key": "limit", "value": "5" }] }
          }
        }
      ]
    },
    {
      "name": "Documentação",
      "item": [
        {
          "name": "Swagger UI",
          "request": { "method": "GET", "url": { "raw": "{{base_url}}/swagger", "host": ["{{base_url}}"], "path": ["swagger"] } }
        },
        {
          "name": "Swagger YML (raw)",
          "request": { "method": "GET", "url": { "raw": "{{base_url}}/swagger.yml", "host": ["{{base_url}}"], "path": ["swagger.yml"] } }
        }
      ]
    }
  ]
}
